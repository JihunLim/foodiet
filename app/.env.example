# foodiet 클라이언트 환경변수
# 실제 .env 파일은 .gitignore 되며, 이 파일만 리포지토리에 커밋한다.

# ── Supabase (publishable 키 — 클라이언트 embed 가능, RLS가 보호) ──
SUPABASE_URL=https://wyicqxcuhdaangxywypj.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_Lcz1dUKdgrFRPvfp3A-Ttw_U3EFm3bb
SUPABASE_REGION=ap-northeast-2

# ── 기본 로케일 (profiles.locale 초기값과 동기화) ──
DEFAULT_LOCALE=ko
DEFAULT_UNIT_ENERGY=kcal
DEFAULT_UNIT_MASS=kg

# ── Firebase / FCM (클라이언트 파트) ──
# 실제 FCM 서비스 계정 JSON은 Edge Function 환경변수로만 주입 (아래 '주의' 참고)
FIREBASE_PROJECT_ID=foodiet-4f861
APP_BUNDLE_ID=com.jihun.foodiet

# ── Google Sign-In ──
# Firebase Auth → Google Provider 활성화 시 자동 생성되는 "Web application" 타입
# OAuth 2.0 Client ID. Android idToken 을 받으려면 serverClientId 로 필요.
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# ── Kakao (§18.1 #10) ──
# Kakao Developers → 내 앱 → 앱 키 → Native 앱 키
# 클라이언트에 embed 해도 안전 (signInWithIdToken 으로 id_token 만 Supabase 에 전달)
KAKAO_NATIVE_APP_KEY=your_kakao_native_app_key_here
# JavaScript 키 — 웹/카카오톡 공유에 필요 시 사용. MVP 에서는 빈 값이어도 OK.
KAKAO_JS_APP_KEY=

# ──────────────────────────────────────────────────────────────────
# 이하 키는 클라이언트에 embed 금지. Edge Function 환경변수로만 주입한다.
# 참조용으로 이름만 기록 — 실제 값은 Supabase Dashboard → Edge Functions → Secrets.
# ──────────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=            # Edge Function 전용 (service role)
# OPENAI_API_KEY=                       # analyze-entry / generate-coach 전용
# OPENAI_MODEL=gpt-5.4-mini             # Vision 지원 (§18.1 #7)
# LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# FCM_SERVICE_ACCOUNT_JSON=             # Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 JSON 전체
