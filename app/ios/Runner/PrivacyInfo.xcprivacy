<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		Apple 은 iOS 17 부터 "required reason API" 목록과 데이터 수집 목적을
		이 매니페스트로 선언하게 한다. 누락 시 App Store Connect 에서
		ITMS-91053 경고가 떠 업로드가 지연될 수 있음.
		Flutter 플러그인(shared_preferences, path_provider 등)이 자체
		PrivacyInfo.xcprivacy 를 동봉하지만, Runner 자체도 하나 필요하다.
	-->

	<!-- 광고 추적 사용하면 true. foodiet 은 AdMob 을 쓰고, 유저가 ATT 동의
	     시에만 IDFA 를 활용해 개인화 광고를 받는다. 따라서 true. -->
	<key>NSPrivacyTracking</key>
	<true/>

	<!-- 추적에 쓰는 도메인 목록.
	     ⚠️ Apple 검증 규칙: NSPrivacyTracking=true 면 이 array 가 비어있으면 안 됨.
	     비어있으면 ITMS-91064 로 reject (메일 문장과 달리 양방향 검증함).
	     아래는 Google Mobile Ads SDK (AdMob) 가 광고 송수신·트래킹에 쓰는 도메인. -->
	<key>NSPrivacyTrackingDomains</key>
	<array>
		<string>googleads.g.doubleclick.net</string>
		<string>pagead2.googlesyndication.com</string>
		<string>googleadservices.com</string>
	</array>

	<!--
		실제 수집/사용하는 데이터 타입.
		App Store Connect "App Privacy" 화면의 답변과 반드시 일치해야 함.
	-->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<dict>
			<!-- 이메일 주소 (로그인 식별) -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeEmailAddress</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- 사용자 ID (Supabase auth uid) -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeUserID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- 식사 사진 -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePhotosorVideos</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- 건강/피트니스 — 칼로리/영양 기록 -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeHealth</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- 앱 상호작용 (Firebase Analytics) -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- 충돌 데이터 (Crashlytics) -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeCrashData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- 성능 로그 (Performance Monitoring 등) -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePerformanceData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- 기기 ID (IDFA) — ATT 동의 시에만 AdMob 개인화에 사용 -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<true/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeThirdPartyAdvertising</string>
			</array>
		</dict>
	</array>

	<!--
		Required Reason API 선언. Flutter Runner 가 기본적으로 사용하는
		API 들에 대한 사유.
	-->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults — SharedPreferences / Flutter 내부 쓰임.
			     이유 CA92.1: 현재 앱 한정 정보 접근. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<dict>
			<!-- File timestamp — path_provider / image cache 등에서 쓰임.
			     이유 C617.1: 사용자에게 파일 정보를 보여주기 위함. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
		<dict>
			<!-- System boot time — analytics / crash reporting 의존.
			     이유 35F9.1: 이 앱의 기능을 위해서만 사용. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategorySystemBootTime</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>35F9.1</string>
			</array>
		</dict>
		<dict>
			<!-- Disk space — 이미지 캐시/저장 전 여유 체크에 쓰일 수 있음.
			     이유 E174.1: 현재 기기에서의 앱 기능 수행. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryDiskSpace</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>E174.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
